<div>
  <h2>Numero di rifiuti accettati nel <%= @year %> suddivisi per mese</h2>
  <canvas id="disposals"></canvas>
</div>

<div class="my-4">
  <h2>Numero di rifiuti accettati nel <%= @year %> suddivisi per UL</h2>
  <canvas id="uls"></canvas>
</div>

<div class="my-4">
  <h2>Numero di rifiuti accettati nel <%= @year %> suddivisi per EER</h2>
  <canvas id="cers"></canvas>
</div>

<div class="my-4">
  <h2>Costi nel <%= @year %> suddivisi per EER</h2>
  <canvas id="prices"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const disposals = document.getElementById('disposals');

  new Chart(disposals, {
    type: 'bar',
    data: {
      labels: <%= raw json_escape(@labels.to_json) %>,
      datasets: [{
        label: '# di scarichi',
        data: <%= raw json_escape(@disposals.to_json) %>,
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });

  const uls = document.getElementById('uls');

  new Chart(uls, {
    type: 'bar',
    data: {
      labels: <%= raw json_escape(Organization.find(@uls.keys).map(&:code).to_json) %>,
      datasets: [{
        label: '# di scarichi per UL',
        data: <%= raw json_escape(@uls.values.to_json) %>,
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });

  const cers = document.getElementById('cers');

  new Chart(cers, {
    type: 'bar',
    data: {
      labels: <%= raw json_escape(CerCode.find(@cer_codes.keys).map(&:name).to_json) %>,
      datasets: [{
        label: '# di scarichi per EER',
        data: <%= raw json_escape(@cer_codes.values.to_json) %>,
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });

  const prices = document.getElementById('prices');

  new Chart(prices, {
    type: 'bar',
    data: {
      labels: <%= raw json_escape(CerCode.find(@prices.keys).map(&:name).to_json) %>,
      datasets: [{
        label: '# di scarichi per EER',
        data: <%= raw json_escape(@prices.values.to_json) %>,
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });
</script>
